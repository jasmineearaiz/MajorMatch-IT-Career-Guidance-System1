    <style>
        
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #f4f7f4; color: #1a1a1a; line-height: 1.6; }

        /* Navigation */
        nav { background: #163e24; padding: 20px 10%; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; }
        
        .logo { 
            color: white; 
            text-decoration: none; 
            font-weight: 700; 
            font-size: 22px; 
            text-transform: none !important;
            letter-spacing: 0px !important;
        }

        .nav-links a { color: white; text-decoration: none; margin-left: 20px; font-weight: bold; font-size: 13px; }

        /* Header Section */
        .contact-hero {
            background: #163e24;
            color: white;
            padding: 60px 10%;
            text-align: center;
            border-bottom: 8px solid #ffd700;
        }
        .contact-hero h1 { font-size: 38px; margin-bottom: 10px; font-weight: 800; }
        .contact-hero p { font-size: 18px; opacity: 0.9; }

        .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

        /* Team Grid */
        .team-grid { display: flex; justify-content: center; gap: 15px; margin-bottom: 60px; flex-wrap: wrap; }
        .team-card { background: white; border-radius: 20px; padding: 25px 15px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.05); transition: 0.3s; border-bottom: 5px solid transparent; flex: 1; min-width: 200px; }
        .team-card:hover { transform: translateY(-10px); border-bottom: 5px solid #ffd700; }

        .profile-pic { width: 100px; height: 100px; border-radius: 50%; background: #e8f0ea; border: 4px solid #163e24; margin: 0 auto 15px auto; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; color: #163e24; }
        .profile-pic img { width: 100%; height: 100%; object-fit: cover; }

        .team-card h3 { color: #163e24; font-size: 18px; margin-bottom: 5px; font-weight: 700; }
        .team-card span { display: block; color: #1e5631; font-weight: bold; font-size: 10px; text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px; }
        
        /* Buttons */
        .contact-link { display: block; text-decoration: none; background: #1877F2; color: white; padding: 10px; border-radius: 8px; font-size: 11px; font-weight: bold; transition: 0.3s; margin-bottom: 8px; }
        .phone-btn { background: #ffd700; color: #163e24; }

        /* Footer Info */
        .info-section { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 40px; }
        .info-card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); text-align: center; }
        .info-card h2 { color: #163e24; margin-bottom: 15px; font-size: 24px; }
        .footer-btn { display: inline-block; text-decoration: none; padding: 14px 30px; background: #163e24; color: white; border-radius: 50px; font-weight: bold; font-size: 14px; text-transform: uppercase; }

        footer { text-align: center; padding: 60px; color: #888; font-size: 12px; }

        @media (max-width: 768px) { .info-section { grid-template-columns: 1fr; } }
    </style>
</head>
